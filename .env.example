# Copy to .env and fill in. Never commit .env (see .gitignore).

# ── Database ───────────────────────────────────────────────────────────────
# Local Homebrew Postgres (default OS user). For Supabase, paste its connection
# string here instead. The RO role backs the text-to-SQL path (see db/roles.sql).
DATABASE_URL=postgresql+psycopg://YOUR_OS_USER@localhost:5432/vayu
DATABASE_URL_RO=postgresql+psycopg://vayu_ro:changeme@localhost:5432/vayu

# ── LLM provider fallback chain (OpenAI-compatible) ────────────────────────
# vayu/llm.py tries each CONFIGURED provider in order until one answers. Set as
# many or as few as you like. (Anthropic is not OpenAI-compatible — see below.)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Native Anthropic (optional; drop in a real sk-ant- key to prefer Claude)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Embeddings for RAG (optional; no corpus until phase-2 monographs)
# VOYAGE_API_KEY=
# EMBEDDING_MODEL=voyage-3
# EMBEDDING_DIM=1024

# ── Wiring ─────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
ENV=local
LOG_LEVEL=INFO
